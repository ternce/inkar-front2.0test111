{
	admin off
	persist_config off
	auto_https off
	log {
		format json
	}
	servers {
		trusted_proxies static private_ranges 100.0.0.0/8
	}
}

:{$PORT:3000} {
	log {
		format json
	}

	# Railway health check
	rewrite /health /*

	root * dist
	encode gzip
	file_server

	# SPA fallback for client-side routing
	try_files {path} /index.html
}
